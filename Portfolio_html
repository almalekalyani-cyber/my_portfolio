<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kalyani Almale | Portfolio</title>

<style>

/* GENERAL */

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, sans-serif;
}

body{
background:#f5f6fa;
color:#333;
}

/* NAVBAR */

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 8%;
background:white;
box-shadow:0 3px 10px rgba(0,0,0,0.1);
position:sticky;
top:0;
z-index:100;
}

.logo{
font-weight:bold;
font-size:20px;
color:#6c63ff;
}

nav ul{
display:flex;
list-style:none;
gap:20px;
}

nav ul li a{
text-decoration:none;
color:#333;
font-weight:500;
}

nav ul li a:hover{
color:#6c63ff;
}

/* HERO */

.hero{
height:80vh;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
background:linear-gradient(120deg,#6c63ff,#5a54d1);
color:white;
padding:20px;
}

.hero h1{
font-size:42px;
margin-bottom:10px;
}

.hero p{
font-size:20px;
margin-bottom:20px;
}

.hero a{
background:white;
color:#6c63ff;
padding:10px 20px;
border-radius:30px;
text-decoration:none;
font-weight:bold;
}

/* SECTION */

section{
padding:70px 8%;
}

.section-title{
text-align:center;
font-size:30px;
margin-bottom:40px;
color:#6c63ff;
}

/* ABOUT */

.about{
max-width:700px;
margin:auto;
text-align:center;
font-size:18px;
line-height:1.6;
}

/* SKILLS */

.skill{
margin-bottom:20px;
}

.skill-name{
margin-bottom:6px;
}

.skill-bar{
background:#ddd;
height:10px;
border-radius:20px;
overflow:hidden;
}

.skill-level{
height:10px;
background:#6c63ff;
}

/* PROJECTS */

.projects-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.project-card{
background:white;
padding:25px;
border-radius:12px;
box-shadow:0 6px 15px rgba(0,0,0,0.08);
transition:.3s;
}

.project-card:hover{
transform:translateY(-6px);
}

.project-card h3{
margin-bottom:10px;
}

.project-btn{
display:inline-block;
margin-top:12px;
background:#ff7a18;
color:white;
padding:8px 15px;
border-radius:6px;
text-decoration:none;
}

/* CONTACT */

.contact{
text-align:center;
}

.contact a{
color:#6c63ff;
text-decoration:none;
font-weight:bold;
}

/* FOOTER */

footer{
text-align:center;
padding:20px;
background:#222;
color:white;
margin-top:40px;
}

/* SERVICES */

.services-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
margin-top:20px;
}

.service-card{
background:#fff;
padding:20px;
border-radius:12px;
box-shadow:0 6px 14px rgba(0,0,0,.08);
transition:.3s;
}

.service-card:hover{
transform:translateY(-6px);
}

.service-card h3{
color:#e0642b;
margin-bottom:10px;
}


/* RESPONSIVE */

@media(max-width:768px){

.hero h1{
font-size:30px;
}

nav ul{
gap:12px;
}

}

</style>
</head>

